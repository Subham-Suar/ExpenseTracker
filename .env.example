# ExpenseTracker Root Environment Variables
# Copy this template to .env in root if needed for deployment scripts

# Backend Configuration
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Expense

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Email (Optional - for expense export feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
FROM_EMAIL=noreply@expensetracker.com
